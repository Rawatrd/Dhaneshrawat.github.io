{"cells":[{"cell_type":"code","source":["import time\n","import sys\n","import numpy as np # REQUIRED for the Intentionality Score calculation\n","from typing import List, Tuple\n","\n","# --- 1. CONFIGURATION AND CORE GAME FUNCTIONS ---\n","\n","# Constants for better readability\n","SPEED = 0.03\n","FRAME_WIDTH = 60\n","\n","# Intentionality Vectors (S): [Strength, Stealth, Intellect]\n","# These vectors define the player's cognitive readiness for different types of challenges (dO).\n","CLASS_INTENTIONALITY = {\n","    \"warrior\": np.array([1.0, 0.2, 0.4]), # High Strength (D&D Fighter/Barbarian)\n","    \"rogue\": np.array([0.3, 1.0, 0.5]),   # High Stealth (D&D Rogue/Thief)\n","    \"mage\": np.array([0.4, 0.3, 1.0]),    # High Intellect (HP Scholar/D&D Wizard)\n","    \"adventurer\": np.array([0.5, 0.5, 0.5]) # Balanced default\n","}\n","\n","# House Alignment Modifiers (Delta S)\n","# These adjust the base Intentionality Vector based on House traits.\n","HOUSE_MODIFIERS = {\n","    \"gryffindor\": np.array([0.1, 0.0, 0.0]), # Courage/Strength boost\n","    \"slytherin\": np.array([0.0, 0.1, 0.0]),  # Ambition/Stealth boost\n","    \"ravenclaw\": np.array([0.0, 0.0, 0.1]),  # Wisdom/Intellect boost\n","    \"hufflepuff\": np.array([0.05, 0.05, 0.0]) # Loyalty/General Hard Work boost\n","}\n","\n","\n","# The Path (C): A list to store the 'Object Differentials' (dO) of the player's choices.\n","# Each dO vector represents the alignment cost/gain of a specific choice: [dStrength, dStealth, dIntellect]\n","JOURNEY_PATH: List[np.ndarray] = []\n","\n","\n","def type_writer(text, speed=SPEED):\n","    \"\"\"Effect to make text look like it's being typed live.\"\"\"\n","    for char in text:\n","        sys.stdout.write(char)\n","        sys.stdout.flush()\n","        time.sleep(speed)\n","    print() # New line at the end\n","\n","def print_frame(title):\n","    \"\"\"Creates a visual 'Frame' for the game UI.\"\"\"\n","    print(\"\\n\" + \"=\"*FRAME_WIDTH)\n","    print(f\" {title.upper()}\")\n","    print(\"=\"*FRAME_WIDTH)\n","\n","def game_over(reason):\n","    \"\"\"Handles game termination.\"\"\"\n","    print_frame(\"GAME OVER\")\n","    type_writer(f\"\\n{reason}\")\n","    print(\"\\n[SYSTEM]: Simulation Terminated.\")\n","    sys.exit()\n","\n","def calculate_intentionality_score(intentionality_vector: np.ndarray, journey_path: List[np.ndarray]) -> float:\n","    \"\"\"\n","    Calculates Accumulated Intentionality (M) using a numerical approximation of the path integral.\n","    M = Integral_C (S . dO)\n","\n","    This function implements the Intentionality calculation logic.\n","    \"\"\"\n","    if len(journey_path) < 1:\n","        return 0.0\n","\n","    S = intentionality_vector\n","    accumulated_intentionality = 0.0\n","\n","    for dO in journey_path:\n","        # np.dot(S, dO) is the instantaneous alignment gain/cost\n","        dot_product = np.dot(S, dO)\n","        accumulated_intentionality += dot_product\n","\n","    # Normalize the result by the number of steps to keep the score in a readable range\n","    normalized_score = accumulated_intentionality / len(journey_path)\n","    return normalized_score\n","\n","# --- 2. GAME SCENES (CHAPTERS) ---\n","# Scenes remain unchanged, as the core logic is now handled in the 'main' function's setup.\n","\n","def scene_catacombs_entrance(player_class: str) -> Tuple[bool, np.ndarray]:\n","    \"\"\"Chapter 1: The Sphinx's Sorting Gate (HP/Fantasy Entrance).\"\"\"\n","    print_frame(\"LOCATION: The Sphinx's Sorting Gate (Chapter 1)\")\n","\n","    story_text = (\n","        \"\\nYou stand before the Great Hall's entrance. The Obsidian Door is now a shimmering, Enchanted Barrier.\\n\"\n","        \"A sculpted stone Sphinx animates, blocking your path. It speaks in a deep, echoing voice:\\n\\n\"\n","        \"'I have cities, but no houses.\\n\"\n","        \" I have mountains, but no trees.\\n\"\n","        \" I have water, but no fish.\\n\"\n","        \" What am I?'\\n\"\n","    )\n","    type_writer(story_text)\n","\n","    if player_class == \"mage\":\n","        print(f\"[LORE HINT]: As a {player_class.capitalize()}, you recall this riddle from the First Year's Orientation Lore.\")\n","    elif player_class == \"warrior\":\n","        print(f\"[D&D HINT]: As a {player_class.capitalize()}, you sense a point of focused energy where the Sphinx connects to the wall.\")\n","\n","    print(\"\\nOPTIONS:\")\n","    print(\"1. Speak the answer (Riddle Solution).\")\n","    print(\"2. Try to disrupt the enchantment via brute force (Bypass).\")\n","    print(\"3. Retreat.\")\n","\n","    choice = input(\"\\n> \")\n","\n","    if choice == \"1\":\n","        answer = input(\"\\nWhat is the answer? > \").lower().strip()\n","        if answer == \"map\":\n","            type_writer(\"\\nThe Sphinx nods slowly. The Barrier dissolves into shimmering dust. Well done!\")\n","            # dO for Intellect-based solution: [dStrength, dStealth, dIntellect]\n","            return True, np.array([0.1, 0.0, 0.8])\n","        else:\n","            type_writer(\"\\n'Incorrect.' The Barrier pulses red and blasts you with pure force.\")\n","            game_over(\"The riddle's magic stopped your heart.\")\n","\n","    elif choice == \"2\":\n","        if player_class == \"warrior\":\n","            type_writer(\"\\nIgnoring the magic, you slam your hilt into the energy nexus. The enchantment destabilizes, creating a hole you can squeeze through!\")\n","            # dO for Strength-based solution: [dStrength, dStealth, dIntellect]\n","            return True, np.array([0.9, -0.2, 0.0])\n","        else:\n","            type_writer(\"\\nYou strike the barrier, but the feedback stings your hand severely.\")\n","            game_over(\"Injured by the magical feedback, you are unable to continue.\")\n","\n","    elif choice == \"3\":\n","        game_over(\"You walked away from destiny and forfeited your enrollment.\")\n","\n","    else:\n","        print(\"Invalid command.\")\n","        return scene_catacombs_entrance(player_class)\n","\n","    return False, np.array([0.0, 0.0, 0.0])\n","\n","def scene_tomb_of_the_scribe(player_class: str) -> Tuple[bool, np.ndarray]:\n","    \"\"\"Chapter 2: The Potions Master's Vault (HP Lore Challenge).\"\"\"\n","    print_frame(\"LOCATION: Potions Master's Vault (Chapter 2)\")\n","\n","    story_text = (\n","        \"\\nThis circular room is now a dimly lit Potion Storage Vault. Ancient flasks bubble gently.\\n\"\n","        \"A heavily locked, iron-bound cabinet holds the key to the next section. A cryptic note is affixed to the lock:\\n\\n\"\n","        \"'I am taken from a mine and shut up in a wooden case.\\n\"\n","        \" I am never to be released, but used by almost everyone.\\n\"\n","        \" What am I?'\\n\"\n","    )\n","    type_writer(story_text)\n","\n","    if player_class == \"mage\":\n","        print(f\"[ALCHEMY HINT]: As a {player_class.capitalize()}, you recognize the material described as a common alchemical binder.\")\n","    elif player_class == \"rogue\":\n","        print(f\"[THIEF HINT]: As a {player_class.capitalize()}, you notice the cabinet hinges are poorly fitted and have recent pry marks.\")\n","\n","    print(\"\\nOPTIONS:\")\n","    print(\"1. Speak the answer (Riddle Solution).\")\n","    print(\"2. Attempt to bypass the hinge mechanism (Precision/Stealth).\")\n","    print(\"3. Smash the heavy cabinet lock with force.\")\n","\n","    choice = input(\"\\n> \")\n","\n","    if choice == \"1\":\n","        answer = input(\"\\nWhat is the answer? > \").lower().strip()\n","        if answer == \"graphite\":\n","            type_writer(\"\\nThe lock clicks open! The solution was a test of basic Alchemical knowledge.\")\n","            # dO for Intellect-based solution: [dStrength, dStealth, dIntellect]\n","            return True, np.array([0.0, 0.1, 0.9])\n","        else:\n","            type_writer(\"\\nThe note glows and emits a sleeping gas!\")\n","            if player_class == \"warrior\":\n","                 type_writer(\"Your great constitution allows you to hold your breath and stagger away, but the lock resets.\")\n","                 return scene_tomb_of_the_scribe(player_class)\n","            else:\n","                game_over(\"You inhaled the gas and fell into an eternal slumber.\")\n","\n","    elif choice == \"2\":\n","        if player_class == \"rogue\":\n","            type_writer(\"\\nUsing a thin tool, you meticulously disassemble the weak hinges. The heavy lock remains intact, but the cabinet opens!\")\n","            # dO for Stealth/Wits-based solution: [dStrength, dStealth, dIntellect]\n","            return True, np.array([0.1, 0.8, 0.2])\n","        else:\n","            type_writer(\"\\nYou try to pry the hinges, but the cabinet is too solid. Your tool snaps, and the noise alerts a patrolling ghoul.\")\n","            game_over(\"The ghoul, summoned by your clumsy actions, consumed you.\")\n","\n","    elif choice == \"3\":\n","        if player_class == \"warrior\":\n","            type_writer(\"\\n*CRACK!* You shatter the heavy lock with a single, powerful blow! The cabinet door flies open.\")\n","            # dO for Strength-based solution: [dStrength, dStealth, dIntellect]\n","            return True, np.array([0.7, -0.3, 0.0])\n","        else:\n","            type_writer(\"\\nYour attempt is futile. The metal is too strong, and the resulting clang draws unwanted attention...\")\n","            game_over(\"A shadow creature emerged from the corner and consumed you.\")\n","\n","    else:\n","        print(\"Invalid command. Choose 1, 2, or 3.\")\n","        return scene_tomb_of_the_scribe(player_class)\n","\n","    return False, np.array([0.0, 0.0, 0.0])\n","\n","def scene_battle_chamber(player_class: str) -> Tuple[bool, np.ndarray]:\n","    \"\"\"Chapter 3: Defense Against the Dark Arts Trial (D&D Combat with HP Spells).\"\"\"\n","    print_frame(\"LOCATION: The Defense Charm Nexus (Chapter 3)\")\n","\n","    story_text = (\n","        \"\\nAn immense, Charmed Gargoyle stands in the arena, powered by an internal spell core. \\n\"\n","        \"It is slow, armored, and guards the final staircase. You must defeat it using skill, spell, or force.\\n\"\n","        \"The **Gargoyle** requires high output across Strength, Precision, or Spellcraft to defeat.\\n\"\n","    )\n","    type_writer(story_text)\n","\n","    print(\"\\nOPTIONS:\")\n","    print(\"1. Brute Force the Stone Shell (D&D Fighter Attack).\")\n","    print(\"2. Disarm the Internal Charm (HP Disarming Charm / Rogue Precision).\")\n","    print(\"3. Blast the Rune Core with a Spell (HP Stupefy / Mage Arcana).\")\n","\n","    choice = input(\"\\n> \")\n","\n","    if choice == \"1\":\n","        # Action alignment vector (dO) for brute force: High Strength\n","        dO_choice = np.array([0.8, 0.0, 0.1])\n","        type_writer(\"\\nYou unleash a devastating flurry of blows, targeting the Gargoyle's thickest armor!\")\n","        # Warrior is best aligned with this choice.\n","        if player_class == \"warrior\":\n","            type_writer(\"Your pure strength shatters the stone. The Gargoyle's chassis collapses!\")\n","            return True, dO_choice\n","        else:\n","            type_writer(\"The stone shell repels your attack, and the Gargoyle counter-smashes you.\")\n","            game_over(\"You lacked the raw strength to bypass its enchanted defense.\")\n","\n","    elif choice == \"2\":\n","        # Action alignment vector (dO) for precision: High Stealth/Precision\n","        dO_choice = np.array([0.2, 0.9, 0.3])\n","        type_writer(\"\\nYou dash into the Gargoyle's shadow, searching for the invisible point where the 'Disarming Charm' is focused.\")\n","        # Rogue is best aligned with this choice.\n","        if player_class == \"rogue\":\n","            type_writer(\"You find the faint nexus and drive your dagger in. The charm fizzles, and the Gargoyle freezes solid!\")\n","            return True, dO_choice\n","        else:\n","            type_writer(\"You trip on a loose stone. The Gargoyle catches you and crushes you in its fist.\")\n","            game_over(\"Your lack of agility betrayed you.\")\n","\n","    elif choice == \"3\":\n","        # Action alignment vector (dO) for insight: High Intellect/Arcana\n","        dO_choice = np.array([0.1, 0.1, 0.9])\n","        type_writer(\"\\nYou raise your hand and channel Arcane power, aiming to disrupt the central Rune Core with a focused spell!\")\n","        # Mage is best aligned with this choice.\n","        if player_class == \"mage\":\n","            type_writer(\"The **STUPEFY** spell hits the core! The Gargoyle explodes into harmless gravel!\")\n","            return True, dO_choice\n","        else:\n","            type_writer(\"Your spell misfires, giving the Gargoyle a chance to lunge forward.\")\n","            game_over(\"The lack of Arcane mastery proved fatal.\")\n","\n","    else:\n","        print(\"Invalid command. Choose 1, 2, or 3.\")\n","        return scene_battle_chamber(player_class)\n","\n","    return False, np.array([0.0, 0.0, 0.0])\n","\n","# --- 3. MAIN GAME LOOP ---\n","\n","def main():\n","    global JOURNEY_PATH\n","\n","    # --- SETUP FRAME ---\n","    print_frame(\"SYSTEM BOOT: MAGICAL CATACOMBS\")\n","    time.sleep(0.5)\n","\n","    # 1. CLASS SELECTION\n","    print(\"Select your Primary Archetype (D&D Focus):\")\n","    print(\"a) Warrior (Strength & Endurance)\")\n","    print(\"b) Rogue (Stealth & Wits)\")\n","    print(\"c) Mage (Intellect & Lore)\")\n","\n","    role_choice = input(\"\\nSelect [a/b/c]: \").lower()\n","\n","    if role_choice == \"a\":\n","        player_class = \"warrior\"\n","    elif role_choice == \"b\":\n","        player_class = \"rogue\"\n","    elif role_choice == \"c\":\n","        player_class = \"mage\"\n","    else:\n","        player_class = \"adventurer\"\n","\n","    # 2. HOUSE ALIGNMENT (THEMATIC INFLUENCE)\n","    print_frame(\"THE SORTING CEREMONY (HP Influence)\")\n","    print(\"The Sorting Hat considers your core values. Choose your House:\")\n","    print(\"1. Gryffindor (Courage & Daring)\")\n","    print(\"2. Slytherin (Ambition & Cunning)\")\n","    print(\"3. Ravenclaw (Wisdom & Wit)\")\n","    print(\"4. Hufflepuff (Loyalty & Patience)\")\n","\n","    house_choice = input(\"\\nSelect [1/2/3/4]: \")\n","\n","    if house_choice == \"1\":\n","        house = \"gryffindor\"\n","    elif house_choice == \"2\":\n","        house = \"slytherin\"\n","    elif house_choice == \"3\":\n","        house = \"ravenclaw\"\n","    elif house_choice == \"4\":\n","        house = \"hufflepuff\"\n","    else:\n","        house = \"hufflepuff\" # Default to balanced\n","\n","    house_modifier = HOUSE_MODIFIERS[house]\n","\n","    # 3. CALCULATE FINAL INTENTIONALITY VECTOR (S)\n","    base_vector = CLASS_INTENTIONALITY[player_class]\n","    player_vector = base_vector + house_modifier\n","\n","    print_frame(\"CHARACTER INITIATED\")\n","    type_writer(f\"Archetype: {player_class.upper()}\")\n","    type_writer(f\"House: {house.upper()}\")\n","    type_writer(f\"\\nFinal Intentionality Vector (S): {player_vector}\")\n","    time.sleep(1)\n","\n","    # --- CHAPTER 1 START ---\n","    chapter1_success, dO1 = scene_catacombs_entrance(player_class)\n","    if chapter1_success:\n","        JOURNEY_PATH.append(dO1)\n","        print_frame(\"CHAPTER 1 COMPLETE: The Great Hall\")\n","        type_writer(\"\\nWith the riddle solved, the path to the forbidden archives is open...\")\n","        time.sleep(1)\n","\n","        # --- CHAPTER 2 START ---\n","        chapter2_success, dO2 = scene_tomb_of_the_scribe(player_class)\n","\n","        if chapter2_success:\n","            JOURNEY_PATH.append(dO2)\n","            print_frame(\"CHAPTER 2 COMPLETE: Vault Unlocked\")\n","            type_writer(\"\\nYou have overcome the test of lore and continue toward the inner defenses.\")\n","            time.sleep(1)\n","\n","            # --- CHAPTER 3 START ---\n","            chapter3_success, dO3 = scene_battle_chamber(player_class)\n","\n","            if chapter3_success:\n","                JOURNEY_PATH.append(dO3)\n","                print_frame(\"CHAPTER 3 COMPLETE: Trial Conquered\")\n","                type_writer(\"\\nThe Defense Charm is broken. You have cleared the path to the Inner Sanctum.\")\n","\n","                # --- FINAL PROGRESS REPORT CALCULATION ---\n","                final_score = calculate_intentionality_score(player_vector, JOURNEY_PATH)\n","\n","                print_frame(\"ACADEMIC PROGRESS REPORT\")\n","                type_writer(f\"Archetype: {player_class.upper()}\")\n","                type_writer(f\"House: {house.upper()}\")\n","                type_writer(f\"Intentionality Vector (S): {player_vector}\")\n","                type_writer(f\"Path History (C) Length: {len(JOURNEY_PATH)} successful choices.\")\n","                type_writer(f\"\\nYour **Accumulated Intentionality Score (M)** is calculated via the path integral $\\int (S \\cdot dO)$:\")\n","                type_writer(f\"\\n\\tM SCORE: {final_score:.4f}\")\n","\n","                if final_score >= 0.7:\n","                    type_writer(\"\\nThis high M Score indicates a mastery of challenges aligned with your chosen Archetype. Excellent execution!\")\n","                elif final_score >= 0.5:\n","                    type_writer(\"\\nThis M Score indicates consistent performance, though some choices required minor misalignment. Good effort!\")\n","                else:\n","                    type_writer(\"\\nThis M Score suggests a low alignment between your choices and your Intentionality. Future choices may need adjustment.\")\n","\n","                print(\"\\n[End of Prototype - Next: The Inner Sanctum]\")\n","\n","# Run the program\n","if __name__ == \"__main__\":\n","    try:\n","        main()\n","    except Exception as e:\n","        # Catch unexpected errors during the game\n","        print(f\"\\n[SYSTEM ERROR]: An unexpected error occurred: {e}\")"],"outputs":[],"execution_count":null,"metadata":{"id":"rGnKd6CSX24K"}}],"metadata":{"colab":{"provenance":[]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}